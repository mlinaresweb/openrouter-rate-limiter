{
  "name": "openrouter-rate-limiter",
  "version": "0.1.0",
  "description": "Production-ready OpenRouter rate limiter with retries, Retry-After handling, cooldown persistence, fetch wrapper and SDK-style client.",
  "type": "module",
  "license": "Apache-2.0",
  "author": {
    "name": "Manel Linares",
    "url": "https://github.com/mlinaresweb"
  },
  "homepage": "https://github.com/mlinaresweb/openrouter-rate-limiter#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mlinaresweb/openrouter-rate-limiter.git"
  },
  "bugs": {
    "url": "https://github.com/mlinaresweb/openrouter-rate-limiter/issues"
  },
  "keywords": [
    "openrouter",
    "rate-limit",
    "rate-limiter",
    "retry",
    "retry-after",
    "cooldown",
    "ai",
    "llm",
    "fetch",
    "typescript",
    "nodejs"
  ],
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE.md",
    "package.json"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": false
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "tsup",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "verify:consumer": "tsx scripts/verify-package-consumption.ts",
    "pack:dry": "npm run clean && npm run check && npm run test && npm run build && npm pack --dry-run",
    "pack:local": "npm run clean && npm run check && npm run test && npm run build && npm pack",
    "release:check": "npm run clean && npm run check && npm run test && npm run build && npm run verify:consumer && npm pack --dry-run",
    "publish:dry": "npm run release:check && npm publish --dry-run --access public",
    "publish:public": "npm run release:check && npm publish --access public",
    "prepublishOnly": "npm run release:check"
  },
  "dependencies": {},
  "devDependencies": {
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.7"
  }
}